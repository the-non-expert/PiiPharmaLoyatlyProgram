# Supabase (PUBLIC_ prefix = exposed to client, no prefix = server-only)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OTP — WhatsApp Business API (primary)
WHATSAPP_API_TOKEN=your-whatsapp-token-here
WHATSAPP_PHONE_ID=your-phone-number-id-here

# OTP — SMS fallback
SMS_API_KEY=your-sms-api-key-here

# Admin credentials (seeded, not self-registered)
ADMIN_EMAIL=admin@piipharma.com
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here
